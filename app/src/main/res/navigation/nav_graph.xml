<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">   <!-- ← this must exist -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.tubes.nimons360.ui.HomeFragment"
        android:label="Home" >
        <action
            android:id="@+id/action_homeFragment_to_familiesFragment"
            app:destination="@id/familiesFragment" />
        <action
            android:id="@+id/action_homeFragment_to_mapFragment2"
            app:destination="@id/mapFragment" />
    </fragment>
    <fragment
        android:id="@+id/familiesFragment"
        android:name="com.tubes.nimons360.ui.FamiliesFragment"
        android:label="fragment_families"
        tools:layout="@layout/fragment_families" />
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.tubes.nimons360.ui.MapFragment"
        android:label="fragment_map"
        tools:layout="@layout/fragment_map" />

</navigation>